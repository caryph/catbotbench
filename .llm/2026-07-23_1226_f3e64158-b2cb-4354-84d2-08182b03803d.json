        "+    return '$' + c.toFixed(2);",
        "+  }",
        "+",
        "+  function placeTip(clientX, clientY) {",
        "+    const r = TIP.getBoundingClientRect();",
        "+    const pad = 14;",
        "+    let x = clientX + pad;",
        "+    if (x + r.width > window.innerWidth - 8) x = clientX - r.width - pad;",
        "+    if (x < 8) x = 8;",
        "+    let y = clientY - r.height - pad;",
        "+    if (y < 8) y = clientY + pad;",
        "+    TIP.style.left = x + 'px';",
        "+    TIP.style.top = y + 'px';",
        "+  }",
        "+",
        "+  function buildTip(m, questions) {",
        "+    const pct = Math.round((m.score / m.total) * 100);",
        "+    const meta = [`<span>${m.score}/${m.total}</span> correct (${pct}%)`];",
        "+    if (m.time) meta.push(`<span>${m.time}s</span>`);",
        "+    meta.push(`<span>${fmtMoney(m.cost)}</span>`);",
        "+    const rows = questions.map(q => {",
        "+      const ok = !!m.per_q[q.q];",
        "+      const mark = ok ? '<span class=\"tt-mark yes\">✓</span>' : '<span class=\"tt-mark no\">✕</span>';",
        "+      return `<div class=\"tt-q\">${mark}<span class=\"tt-qtxt\">${q.q}</span></div>`;",
        "+    }).join('');",
        "+    return `<div class=\"tt-head\">${m.model}</div><div class=\"tt-meta\">${meta.join(' &middot; ')}</div><div class=\"tt-qlist\">${rows}</div>`;",
        "+  }",
        "+",
        "+  function attachBarEvents(bar, m, questions) {",
        "+    bar.addEventListener('mouseenter', () => {",
        "+      TIP.innerHTML = buildTip(m, questions);",
        "+      TIP.classList.add('show');",
        "+      placeTip(...lastMouse);",
        "+    });",
        "+    bar.addEventListener('mousemove', e => {",
        "+      lastMouse = [e.clientX, e.clientY];",
        "+      placeTip(e.clientX, e.clientY);",
        "+    });",
        "+    bar.addEventListener('mouseleave', () => TIP.classList.remove('show'));",
        "+  }",
        "+  let lastMouse = [0, 0];",
