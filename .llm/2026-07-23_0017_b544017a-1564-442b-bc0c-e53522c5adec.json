      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>CatBotBench</title>\n<meta name=\"description\" content=\"CatBotBench — how well do LLMs know Discord Cat Bot?\">\n<style>\n  :root {\n    --bg: #0e0f12;\n    --bg-elev: #16181d;\n    --bg-bar: #2a2d33;\n    --fg: #e6e7ea;\n    --fg-dim: #9a9da4;\n    --fg-faint: #6b6e75;\n    --accent: #ff9f43;\n    --border: #2a2d33;\n    --grid: #303239;\n  }\n  * { box-sizing: border-box; }\n  html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }\n  body {\n    background: linear-gradient(160deg, #0a0b0e 0%, #141518 40%, #1a1420 100%);\n    color: var(--fg);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Inter, Roboto, Helvetica, Arial, sans-serif;\n    line-height: 1.6;\n    -webkit-font-smoothing: antialiased;\n    display: flex;\n    flex-direction: column;\n  }\n  .wrap { max-width: 920px; margin: 0 auto; padding: 0 24px; width: 100%; }\n\n  header.hero {\n    padding: 48px 0 20px;\n    text-align: center;\n  }\n  .hero .eyebrow {\n    color: var(--accent);\n    font-size: 0.75rem;\n    font-weight: 600;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    margin: 0 0 8px;\n  }\n  .hero h1 {\n    font-size: 2rem;\n    margin: 0 0 10px;\n    letter-spacing: -0.02em;\n  }\n  .hero p.lead {\n    color: var(--fg-dim);\n    font-size: 0.88rem;\n    max-width: 520px;\n    margin: 0 auto;\n    line-height: 1.5;\n  }\n  .hero .links {\n    margin-top: 12px;\n    font-size: 0.78rem;\n  }\n  .hero .links a {\n    color: var(--fg-faint);\n    text-decoration: none;\n    border-bottom: 1px solid var(--fg-faint);\n    transition: color 0.15s, border-color 0.15s;\n  }\n  .hero .links a:hover {\n    color: var(--accent);\n    border-color: var(--accent);\n  }\n\n  main {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    min-height: 0;\n    padding: 0 0 12px;\n  }\n  section { flex: 1; display: flex; flex-direction: column; min-height: 0; }\n  h2 {\n    font-size: 0.95rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n    letter-spacing: -0.01em;\n    text-align: center;\n  }\n  .section-sub {\n    color: var(--fg-faint);\n    font-size: 0.78rem;\n    margin: 0 0 12px;\n    text-align: center;\n  }\n\n  .chart {\n    display: flex;\n    align-items: flex-end;\n    gap: 10px;\n    flex: 1;\n    min-height: 0;\n    padding: 24px 4px 0;\n    border-bottom: 1px solid var(--grid);\n    background-image: repeating-linear-gradient(to top, var(--grid) 0 1px, transparent 1px 20%);\n    background-origin: content-box;\n    background-clip: content-box;\n    overflow-x: auto;\n  }\n  .col {\n    flex: 1 1 0;\n    min-width: 56px;\n    height: 100%;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n  }\n  .bar {\n    width: 80%;\n    max-width: 44px;\n    background: var(--bar-color, var(--accent));\n    border-radius: 6px 6px 0 0;\n    height: 0;\n    transition: height 0.9s cubic-bezier(0.16, 1, 0.3, 1);\n    position: relative;\n    min-height: 3px;\n  }\n  .score-num {\n    position: absolute;\n    top: -22px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 0.78rem;\n    font-weight: 600;\n    color: var(--fg-dim);\n    white-space: nowrap;\n    font-variant-numeric: tabular-nums;\n  }\n  .labels {\n    display: flex;\n    gap: 10px;\n    padding: 10px 4px 0;\n    overflow: visible;\n  }\n  .label-block {\n    flex: 1 1 0;\n    min-width: 56px;\n    text-align: center;\n    overflow: visible;\n  }\n  .logo {\n    width: 20px; height: 20px;\n    object-fit: contain;\n    margin: 0 auto 4px;\n    display: block;\n  }\n  .model-name {\n    font-size: 0.72rem;\n    color: var(--fg-dim);\n    white-space: nowrap;\n    display: inline-block;\n    transform: rotate(-30deg);\n    transform-origin: top center;\n  }\n\n  #dvdcat {\n    position: fixed;\n    top: 0; left: 0;\n    width: 256px;\n    height: 256px;\n    opacity: 0.5;\n    pointer-events: none;\n    z-index: 0;\n    will-change: transform;\n  }\n  #dvdcat img { width: 100%; height: 100%; object-fit: contain; display: block; }\n\n  footer {\n    border-top: 1px solid var(--border);\n    padding: 16px 0;\n    color: var(--fg-faint);\n    font-size: 0.78rem;\n    text-align: center;\n  }\n  footer a { color: var(--fg-dim); text-decoration: none; }\n  footer a:hover { color: var(--accent); }\n</style>\n</head>\n<body>\n  <div id=\"dvdcat\"><img src=\"assets/staring_cat.png\" alt=\"\" draggable=\"false\"></div>\n  <header class=\"hero\">\n    <div class=\"wrap\">\n      <p class=\"eyebrow\">A joke LLM benchmark</p>\n      <h1>CatBotBench</h1>\n      <p class=\"lead\">\n        Five absurdly specific questions about Discord Cat Bot, thrown at\n        a pile of language models. None of them have any business knowing this stuff.\n        Five questions, five points. Higher is better.\n      </p>\n      <div class=\"links\">\n        <a href=\"data.json\" target=\"_blank\">raw questions &amp; scores (JSON)</a>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"wrap\">\n    <section id=\"scores\">\n      <h2>Model scores</h2>\n      <p class=\"section-sub\">Percent correct, lowest to highest</p>\n      <div class=\"chart\" id=\"chart\"></div>\n      <div class=\"labels\" id=\"labels\"></div>\n    </section>\n  </main>\n\n  <footer>\n    <div class=\"wrap\">\n      CatBotBench &middot; a deeply unserious evaluation &middot;\n      <a href=\"https://github.com/tallrocksawakesadhearts/catbotbench\">source</a>\n    </div>\n  </footer>\n\n<script>\n  const CHART = document.getElementById('chart');\n  const LABELS = document.getElementById('labels');\n\n  function render(data) {\n    data.models.forEach(m => {\n      const pct = (m.score / m.total) * 100;\n      const parts = m.model.split('/');\n      const name = parts.slice(1).join('/') || m.model;\n      const col = document.createElement('div');\n      col.className = 'col';\n      col.style.setProperty('--bar-color', m.color || '#ff9f43');\n      col.innerHTML = `<div class=\"bar\" data-h=\"${pct}\"><span class=\"score-num\">${Math.round(pct)}%</span></div>`;\n      CHART.appendChild(col);\n\n      const lb = document.createElement('div');\n      lb.className = 'label-block';\n      const logoHtml = m.logo ? `<img class=\"logo\" src=\"logos/${m.logo}\" alt=\"\" loading=\"lazy\">` : '';\n      lb.innerHTML = `${logoHtml}<div class=\"model-name\" title=\"${m.model}\">${name}</div>`;\n      LABELS.appendChild(lb);\n    });\n    requestAnimationFrame(() => {\n      document.querySelectorAll('.bar').forEach(el => { el.style.height = el.dataset.h + '%'; });\n    });\n  }\n\n  fetch('data.json')\n    .then(r => { if (!r.ok) throw new Error('data.json: HTTP ' + r.status); return r.json(); })\n    .then(render)\n    .catch(err => {\n      CHART.innerHTML = `<p style=\"color:var(--fg-faint);text-align:center;padding:40px 0\">Failed to load data: ${err}</p>`;\n    });\n</script>\n<script>\n  (function () {\n    const cat = document.getElementById('dvdcat');\n    const SIZE = 256;\n    let x = Math.random() * (window.innerWidth - SIZE);\n    let y = Math.random() * (window.innerHeight - SIZE);\n    let vx = 1.2, vy = 1.0;\n    if (Math.random() < 0.5) vx = -vx;\n    if (Math.random() < 0.5) vy = -vy;\n\n    function frame() {\n      const w = window.innerWidth - SIZE;\n      const h = window.innerHeight - SIZE;\n      if (x <= 0) { x = 0; vx = Math.abs(vx); }\n      if (x >= w) { x = w; vx = -Math.abs(vx); }\n      if (y <= 0) { y = 0; vy = Math.abs(vy); }\n      if (y >= h) { y = h; vy = -Math.abs(vy); }\n      cat.style.transform = `translate(${x}px, ${y}px)`;\n      x += vx;\n      y += vy;\n      requestAnimationFrame(frame);\n    }\n    requestAnimationFrame(frame);\n  })();\n</script>\n</body>\n</html>\n"
